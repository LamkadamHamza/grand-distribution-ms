pipeline {
    agent any
    
    // ✅ BONNE PRATIQUE: Options pour nettoyage et contrôle
    options {
        buildDiscarder(logRotator(numToKeepStr: '5'))  // Garde seulement 5 builds
        disableConcurrentBuilds()  // Pas de builds simultanés sur même branche
        skipDefaultCheckout(true)    // On gère le checkout manuellement
    }
    
    environment {
        DOCKER_REGISTRY = 'localhost:5000'
        BUILD_TAG = "${env.BRANCH_NAME}-${env.BUILD_NUMBER}"
    }
    
    stages {
        // ✅ BONNE PRATIQUE: Nettoyer workspace AVANT tout
        stage('Clean Workspace') {
            steps {
                cleanWs()  // Supprime tout le workspace
                checkout scm  // Checkout propre après nettoyage
                echo "✅ Workspace cleaned and code checked out"
            }
        }
        
        stage('Build Parent') {
            steps {
                sh 'mvn clean install -N'
            }
        }
        
        stage('Build Services') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }
        
        stage('Unit Tests') {
            steps {
                sh 'mvn test'
            }
            post {
                always {
                    junit '**/target/surefire-reports/*.xml'
                }
            }
        }
        
        // ✅ BONNE PRATIQUE: Builds Docker en PARALLÈLE
        stage('Build Docker Images') {
            when {
                anyOf {
                    branch 'develop'
                    branch 'preprod'
                    branch 'main'
                }
            }
            steps {
                script {
                    def services = [
                        [name: 'discovery-service', path: 'discovery-service'],
                        [name: 'api-gateway', path: 'api-gateway'],
                        [name: 'product-service', path: 'product-service']
                    ]
                    
                    // Build en parallèle
                    def parallelBuilds = [:]
                    services.each { service ->
                        parallelBuilds["Build ${service.name}"] = {
                            sh """
                                docker build \
                                    -t ${DOCKER_REGISTRY}/${service.name}:${BUILD_TAG} \
                                    -t ${DOCKER_REGISTRY}/${service.name}:latest \
                                    -f ${service.path}/Dockerfile \
                                    ${service.path}
                            """
                        }
                    }
                    parallel parallelBuilds
                }
            }
        }
        
        stage('Push Images') {
            when {
                anyOf {
                    branch 'develop'
                    branch 'preprod'
                    branch 'main'
                }
            }
            steps {
                script {
                    def services = ['discovery-service', 'api-gateway', 'product-service']
                    services.each { service ->
                        sh "docker push ${DOCKER_REGISTRY}/${service}:${BUILD_TAG}"
                    }
                }
            }
        }
        
        stage('Deploy DEV') {
            when {
                branch 'develop'
            }
            steps {
                sh """
                    export BUILD_NUMBER=${BUILD_TAG}
                    docker-compose -f infrastructure/docker/docker-compose.dev.yml down || true
                    docker-compose -f infrastructure/docker/docker-compose.dev.yml up -d
                """
                echo "✅ Déployé sur DEV: http://localhost:8888"
            }
        }
        
        stage('Deploy PREPROD') {
            when {
                branch 'preprod'
            }
            steps {
                sh """
                    export VERSION=${BUILD_TAG}
                    docker-compose -f infrastructure/docker/docker-compose.preprod.yml down || true
                    docker-compose -f infrastructure/docker/docker-compose.preprod.yml up -d
                """
                echo "✅ Déployé sur PREPROD"
            }
        }
        
        stage('Deploy PROD') {
            when {
                branch 'main'
            }
            steps {
                input message: '🚀 Déployer en Production ?', ok: 'Déployer'
                echo "Déploiement Production en cours..."
            }
        }
    }
    
    // ✅ BONNE PRATIQUE: Nettoyer workspace APRÈS tout (même en cas d'erreur)
    post {
        always {
            cleanWs()  // Nettoyage final garanti
            sh 'docker system prune -f || true'
            echo "✅ Workspace cleaned after build"
        }
        success {
            echo "✅ Build ${BUILD_TAG} réussi!"
        }
        failure {
            echo "❌ Build ${BUILD_TAG} échoué"
        }
    }
}
